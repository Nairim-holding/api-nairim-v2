# Ambiente da aplica횄짠횄짙o
NODE_ENV=development

# Porta do servidor
PORT=5000

# URL de conex횄짙o com o banco de dados (PostgreSQL)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/nome_do_banco"

# Chave secreta para JWT (use uma string longa e segura em produ횄짠횄짙o)
JWT_SECRET="sua_chave_jwt_super_secreta_aqui"

# Dura횄짠횄짙o do token de sess횄짙o (m횄짯nimo recomendado: 12h)
JWT_EXPIRES_IN=12h

# URL base da API
BASE_URL="http://localhost:5000"


# Configura횄짠횄짙o de Rate Limiting
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX_REQUESTS=10000

# MinIO - CDN self-hosted (S3 compat횄짯vel)
# Endpoint interno usado pelo SDK para enviar os arquivos (nome do servi횄짠o no docker-compose)
MINIO_ENDPOINT="http://minio:9000"
# URL p횄쨘blica usada para montar o link final salvo no banco (dom횄짯nio exposto via Traefik)
MINIO_PUBLIC_URL="https://cdn.nairim.com.br"
MINIO_ACCESS_KEY="seu_minio_root_user"
MINIO_SECRET_KEY="sua_minio_root_password"
MINIO_BUCKET="imagens"
MINIO_REGION="us-east-1"

# Credenciais do container MinIO (usadas pelo docker-compose para subir o servi횄짠o)
MINIO_ROOT_USER="seu_minio_root_user"
MINIO_ROOT_PASSWORD="sua_minio_root_password"
