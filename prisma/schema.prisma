generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── MULTI-TENANT ────────────────────────────────────────────────────────────

model Company {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  branding                CompanyBranding?
  users                   User[]
  properties              Property[]
  property_types          PropertyType[]
  owners                  Owner[]
  agencies                Agency[]
  tenants                 Tenant[]
  suppliers               Supplier[]
  leases                  Lease[]
  financial_institutions  FinancialInstitution[]
  cards                   Card[]
  transactions            Transaction[]
  invoices                Invoice[]
  categories              Category[]
  subcategories           Subcategory[]
  centers                 Center[]
  recurring_configs       RecurringConfig[]
  plannings               Planning[]
  documents               Document[]
  favorites               Favorite[]
  user_column_preferences UserColumnPreference[]
  user_dashboard_layouts  UserDashboardLayout[]
}

model CompanyBranding {
  id              String   @id @default(uuid())
  company_id      String   @unique
  logo_url        String?
  favicon_url     String?
  primary_color   String?
  secondary_color String?
  company_name    String?
  company_info    Json?

  // Identidade estendida
  trade_name       String?
  app_title        String?
  app_description  String?
  logo_sidebar_url String?
  logo_dark_url    String?
  og_image_url     String?

  // Tema light (cores adicionais — primary/secondary já existem acima)
  accent_color  String?
  success_color String?
  warning_color String?
  error_color   String?
  info_color    String?
  bg_color      String?
  card_color    String?
  border_color  String?
  text_color    String?

  // Tema dark (espelha o conjunto do tema light)
  primary_color_dark   String?
  secondary_color_dark String?
  accent_color_dark    String?
  success_color_dark   String?
  warning_color_dark   String?
  error_color_dark     String?
  info_color_dark      String?
  bg_color_dark        String?
  card_color_dark      String?
  border_color_dark    String?
  text_color_dark      String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
}

// ─── IMOBILIÁRIA ─────────────────────────────────────────────────────────────

model Agency {
  id                     String          @id @default(uuid())
  company_id             String
  trade_name             String
  legal_name             String
  cnpj                   String          @db.VarChar(18)
  state_registration     String?
  municipal_registration String?
  license_number         String?         @db.VarChar(20)
  commission_category_id    String?
  commission_subcategory_id String?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  deleted_at             DateTime?
  addresses              AgencyAddress[]
  contacts               Contact[]
  properties             Property[]
  leases                 Lease[]
  suppliers              Supplier[]
  commission_category    Category?       @relation(fields: [commission_category_id], references: [id])
  commission_subcategory Subcategory?    @relation(fields: [commission_subcategory_id], references: [id])
  company                Company        @relation(fields: [company_id], references: [id])

  @@index([cnpj])
  @@index([commission_category_id])
  @@index([commission_subcategory_id])
  @@index([company_id])
}

model Property {
  id                  String            @id @default(uuid())
  company_id          String
  owner_id            String
  agency_id           String?
  type_id             String
  center_id           String?
  debit_center_id     String?
  category_id         String?
  subcategory_id      String?
  iptu_refund_category_id    String?
  iptu_refund_subcategory_id String?
  title               String
  registration_number String?           @db.VarChar(50)
  bedrooms            Int
  bathrooms           Int
  half_bathrooms      Int
  garage_spaces       Int
  area_total          Float
  area_built          Float
  frontage            Float
  furnished           Boolean
  floor_number        Int?
  tax_registration    String            @db.VarChar(20)
  notes               String?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  deleted_at          DateTime?
  documents           Document[]
  favorites           Favorite[]
  leases              Lease[]
  agency              Agency?           @relation(fields: [agency_id], references: [id])
  owner               Owner             @relation(fields: [owner_id], references: [id])
  type                PropertyType      @relation(fields: [type_id], references: [id])
  center              Center?           @relation("PropertyCreditCenter", fields: [center_id], references: [id])
  debit_center        Center?           @relation("PropertyDebitCenter", fields: [debit_center_id], references: [id])
  category            Category?         @relation("PropertyCategory", fields: [category_id], references: [id])
  subcategory         Subcategory?      @relation("PropertySubcategory", fields: [subcategory_id], references: [id])
  iptu_refund_category    Category?     @relation("PropertyIptuRefundCategory", fields: [iptu_refund_category_id], references: [id])
  iptu_refund_subcategory Subcategory?  @relation("PropertyIptuRefundSubcategory", fields: [iptu_refund_subcategory_id], references: [id])
  addresses           PropertyAddress[]
  iptus               PropertyIptu[]
  values              PropertyValue[]
  company             Company          @relation(fields: [company_id], references: [id])

  @@index([owner_id])
  @@index([agency_id])
  @@index([center_id])
  @@index([debit_center_id])
  @@index([category_id])
  @@index([subcategory_id])
  @@index([iptu_refund_category_id])
  @@index([iptu_refund_subcategory_id])
  @@index([company_id])
}

model PropertyIptu {
  id                                       String            @id @default(uuid())
  property_id                              String
  year                                     Int
  property_tax                             Decimal?          @db.Decimal(20, 2)
  property_tax_cash                        Decimal?          @db.Decimal(20, 2)
  property_tax_cash_due_date               DateTime?         @db.Date
  property_tax_first_installment           Decimal?          @db.Decimal(20, 2)
  property_tax_first_installment_due_date  DateTime?         @db.Date
  property_tax_second_installment          Decimal?          @db.Decimal(20, 2)
  property_tax_second_installment_due_date DateTime?         @db.Date
  iptu_installments_count                  Int?
  iptu_installments                        Json?
  payment_condition                        PaymentCondition?
  created_at                               DateTime          @default(now())
  updated_at                               DateTime          @updatedAt
  deleted_at                               DateTime?
  property                                 Property          @relation(fields: [property_id], references: [id])

  @@index([property_id])
  @@index([year])
}

model User {
  id                String                 @id @default(uuid())
  company_id        String
  name              String
  email             String
  password          String
  birth_date        DateTime               @db.Date
  gender            Gender
  role              Role                   @default(DEFAULT)
  created_at        DateTime               @default(now())
  updated_at        DateTime               @updatedAt
  deleted_at        DateTime?
  documents         Document[]
  favorites         Favorite[]
  columnPreferences UserColumnPreference[]
  dashboardLayouts  UserDashboardLayout[]
  company           Company               @relation(fields: [company_id], references: [id])

  @@unique([company_id, email])
  @@index([company_id])
}

model UserColumnPreference {
  id               String   @id @default(uuid())
  company_id       String
  user_id          String
  resource         String   @db.VarChar(100)
  column_order     Json     @default("[]")
  column_widths    Json     @default("{}")
  visible_columns  Json     @default("[]")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  company          Company @relation(fields: [company_id], references: [id])

  @@unique([user_id, resource])
  @@index([user_id])
  @@index([resource])
  @@index([company_id])
}

model UserDashboardLayout {
  id         String   @id @default(uuid())
  company_id String
  user_id    String
  resource   String   @db.VarChar(100)
  layout     Json     @default("[]")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [company_id], references: [id])

  @@unique([user_id, resource])
  @@index([user_id])
  @@index([resource])
  @@index([company_id])
}

model Document {
  id          String       @id @default(uuid())
  company_id  String
  property_id String?
  lease_id    String?
  created_by  String?
  file_path   String
  file_type   String
  description String?
  type        DocumentType
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  deleted_at  DateTime?
  is_featured Boolean      @default(false)
  user        User?        @relation(fields: [created_by], references: [id])
  property    Property?    @relation(fields: [property_id], references: [id])
  lease       Lease?       @relation(fields: [lease_id], references: [id])
  company     Company     @relation(fields: [company_id], references: [id])

  @@index([property_id])
  @@index([lease_id])
  @@index([company_id])
}

model Owner {
  id                     String         @id @default(uuid())
  company_id             String
  name                   String
  internal_code          String
  occupation             String?
  marital_status         String?
  cpf                    String?        @db.VarChar(14)
  cnpj                   String?        @db.VarChar(20)
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  deleted_at             DateTime?
  municipal_registration String?
  state_registration     String?
  contacts               Contact[]
  leases                 Lease[]
  addresses              OwnerAddress[]
  properties             Property[]
  company                Company       @relation(fields: [company_id], references: [id])

  @@unique([company_id, internal_code])
  @@index([cpf])
  @@index([cnpj])
  @@index([company_id])
}

model Tenant {
  id                     String          @id @default(uuid())
  company_id             String
  name                   String
  internal_code          String
  nationality            String?         @db.VarChar(100)
  occupation             String?
  marital_status         String?
  cpf                    String?         @db.VarChar(14)
  rg                     String?         @db.VarChar(20)
  rg_issuing_body        String?         @db.VarChar(50)
  rg_issuing_state       String?         @db.VarChar(2)
  cnpj                   String?         @db.VarChar(20)
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  deleted_at             DateTime?
  municipal_registration String?
  state_registration     String?
  contacts               Contact[]
  leases                 Lease[]
  addresses              TenantAddress[]
  company                Company        @relation(fields: [company_id], references: [id])

  @@unique([company_id, internal_code])
  @@index([cpf])
  @@index([cnpj])
  @@index([company_id])
}

model Lease {
  id                              String            @id @default(uuid())
  company_id                      String
  property_id                     String
  type_id                         String
  owner_id                        String
  tenant_id                       String
  agency_id                       String?
  financial_institution_id        String?
  contract_number                 String
  start_date                      DateTime          @db.Date
  end_date                        DateTime          @db.Date
  rent_amount                     Decimal           @db.Decimal(20, 2)
  condo_fee                       Decimal?          @db.Decimal(20, 2)
  property_tax                    Decimal?          @db.Decimal(20, 2)
  extra_charges                   Decimal?          @db.Decimal(20, 2)
  commission_amount               Decimal?          @db.Decimal(20, 2)
  rent_due_day                    Int
  tax_due_day                     Int?
  condo_due_day                   Int?
  created_at                      DateTime          @default(now())
  updated_at                      DateTime          @updatedAt
  deleted_at                      DateTime?
  canceled_at                     DateTime?
  cancellation_justification      String?
  cancellation_penalty            Decimal?          @db.Decimal(20, 2)
  other_cancellation_amounts      Decimal?          @db.Decimal(20, 2)
  status                          LeaseStatus       @default(ACTIVE)
  payment_condition                          PaymentCondition?
  property_tax_cash                          Decimal?          @db.Decimal(20, 2)
  property_tax_cash_due_date                 DateTime?         @db.Date
  property_tax_first_installment             Decimal?          @db.Decimal(20, 2)
  property_tax_first_installment_due_date    DateTime?         @db.Date
  property_tax_second_installment            Decimal?          @db.Decimal(20, 2)
  property_tax_second_installment_due_date   DateTime?         @db.Date
  iptu_year                                  Int?
  iptu_installments                          Json?
  iptu_installments_due_dates                Json?
  iptu_installments_count                    Int?
  insurance_company               String?
  insurance_type                  String?
  insurance_policy                String?
  guarantors                      Json?
  owner                           Owner             @relation(fields: [owner_id], references: [id])
  property                        Property          @relation(fields: [property_id], references: [id])
  tenant                          Tenant            @relation(fields: [tenant_id], references: [id])
  type                            PropertyType      @relation(fields: [type_id], references: [id])
  agency                          Agency?               @relation(fields: [agency_id], references: [id])
  financial_institution           FinancialInstitution? @relation(fields: [financial_institution_id], references: [id])
  transactions                    Transaction[]
  documents                       Document[]
  company                         Company          @relation(fields: [company_id], references: [id])

  @@index([property_id])
  @@index([tenant_id])
  @@index([agency_id])
  @@index([financial_institution_id])
  @@index([company_id])
}

model PropertyValue {
  id             String         @id @default(uuid())
  property_id    String
  purchase_value Decimal?       @db.Decimal(20, 2)
  market_value   Decimal?       @db.Decimal(20, 2)
  rental_value   Decimal?       @db.Decimal(20, 2)
  condo_fee      Decimal        @db.Decimal(20, 2)
  property_tax   Decimal        @db.Decimal(20, 2)
  status         PropertyStatus
  notes          String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  deleted_at     DateTime?
  extra_charges  Decimal?       @db.Decimal(20, 2)
  sale_value     Decimal?       @db.Decimal(20, 2)
  sale_date      DateTime?      @db.Date
  purchase_date  DateTime?      @db.Date
  property       Property       @relation(fields: [property_id], references: [id])

  @@index([property_id])
}

model PropertyType {
  id          String     @id @default(uuid())
  company_id  String
  description String
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  deleted_at  DateTime?
  leases      Lease[]
  properties  Property[]
  company     Company   @relation(fields: [company_id], references: [id])

  @@index([company_id])
}

model Address {
  id                String            @id @default(uuid())
  zip_code          String            @db.VarChar(10)
  street            String
  number            String
  district          String
  city              String
  state             String
  country           String
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  deleted_at        DateTime?
  block             String?
  complement        String?
  lot               String?
  latitude          Float?
  longitude         Float?
  agencyAddresses   AgencyAddress[]
  ownerAddresses    OwnerAddress[]
  propertyAddresses PropertyAddress[]
  supplierAddresses SupplierAddress[]
  tenantAddresses   TenantAddress[]
}

model Contact {
  id          String    @id @default(uuid())
  contact     String?
  phone       String?
  email       String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  cellphone   String?
  agency_id   String?
  owner_id    String?
  tenant_id   String?
  supplier_id String?
  agency      Agency?   @relation(fields: [agency_id], references: [id])
  owner       Owner?    @relation(fields: [owner_id], references: [id])
  supplier    Supplier? @relation(fields: [supplier_id], references: [id])
  tenant      Tenant?   @relation(fields: [tenant_id], references: [id])

  @@index([agency_id])
  @@index([owner_id])
  @@index([tenant_id])
  @@index([supplier_id])
}

model Favorite {
  id          String    @id @default(uuid())
  company_id  String
  user_id     String
  property_id String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  property    Property  @relation(fields: [property_id], references: [id])
  user        User      @relation(fields: [user_id], references: [id])
  company     Company  @relation(fields: [company_id], references: [id])

  @@unique([user_id, property_id])
  @@index([company_id])
}

model AgencyAddress {
  id         String    @id @default(uuid())
  agency_id  String
  address_id String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  address    Address   @relation(fields: [address_id], references: [id])
  agency     Agency    @relation(fields: [agency_id], references: [id])
}

model PropertyAddress {
  id          String    @id @default(uuid())
  property_id String
  address_id  String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  address     Address   @relation(fields: [address_id], references: [id])
  property    Property  @relation(fields: [property_id], references: [id])
}

model OwnerAddress {
  id         String    @id @default(uuid())
  owner_id   String
  address_id String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  address    Address   @relation(fields: [address_id], references: [id])
  owner      Owner     @relation(fields: [owner_id], references: [id])
}

model TenantAddress {
  id         String    @id @default(uuid())
  tenant_id  String
  address_id String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  address    Address   @relation(fields: [address_id], references: [id])
  tenant     Tenant    @relation(fields: [tenant_id], references: [id])
}

// ─── FINANCEIRO ───────────────────────────────────────────────────────────────

model FinancialInstitution {
  id                String            @id @default(uuid())
  company_id        String
  name              String
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  deleted_at        DateTime?
  is_active         Boolean           @default(true)
  account_number    String?           @db.VarChar(50)
  agency_number     String?           @db.VarChar(20)
  bank_number       String?           @db.VarChar(20)
  recurring_configs RecurringConfig[]
  transactions      Transaction[]
  leases            Lease[]
  company           Company          @relation(fields: [company_id], references: [id])

  @@index([company_id])
}

model Category {
  id                String            @id @default(uuid())
  company_id        String
  name              String
  type              TransactionType
  is_active         Boolean           @default(true)
  is_system         Boolean           @default(false)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  deleted_at        DateTime?
  recurring_configs RecurringConfig[]
  subcategories     Subcategory[]
  transactions      Transaction[]
  plannings         Planning[]
  properties        Property[]        @relation("PropertyCategory")
  iptu_refund_properties Property[]   @relation("PropertyIptuRefundCategory")
  commission_agencies Agency[]
  company           Company          @relation(fields: [company_id], references: [id])

  @@index([company_id])
}

model Subcategory {
  id                String            @id @default(uuid())
  company_id        String
  category_id       String
  name              String
  is_active         Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  deleted_at        DateTime?
  recurring_configs RecurringConfig[]
  category          Category          @relation(fields: [category_id], references: [id])
  transactions      Transaction[]
  plannings         Planning[]
  properties        Property[]        @relation("PropertySubcategory")
  iptu_refund_properties Property[]   @relation("PropertyIptuRefundSubcategory")
  commission_agencies Agency[]
  company           Company          @relation(fields: [company_id], references: [id])

  @@index([category_id])
  @@index([company_id])
}

model Card {
  id                String            @id @default(uuid())
  company_id        String
  name              String
  limit             Decimal           @default(0) @db.Decimal(20, 2)
  is_active         Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  deleted_at        DateTime?
  closing_day       Int?
  due_day           Int?
  brand             String            @default("Outro")
  current_balance   Decimal           @default(0) @db.Decimal(20, 2)
  recurring_configs RecurringConfig[]
  transactions      Transaction[]
  invoices          Invoice[]
  company           Company          @relation(fields: [company_id], references: [id])

  @@index([company_id])
}

model Center {
  id                String            @id @default(uuid())
  company_id        String
  name              String
  type              TransactionType
  is_active         Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  deleted_at        DateTime?
  recurring_configs RecurringConfig[]
  transactions      Transaction[]
  properties        Property[]       @relation("PropertyCreditCenter")
  debit_properties  Property[]       @relation("PropertyDebitCenter")
  company           Company          @relation(fields: [company_id], references: [id])

  @@index([company_id])
}

model Supplier {
  id                     String            @id @default(uuid())
  company_id             String
  sequential_id          Int               @default(autoincrement())
  legal_name             String
  trade_name             String?
  cnpj                   String?           @db.VarChar(20)
  state_registration     String?
  municipal_registration String?
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  deleted_at             DateTime?
  cpf                    String?           @db.VarChar(14)
  internal_code          String?
  created_via            String?           @default("full_form")
  is_active              Boolean           @default(true)
  marital_status         String?
  occupation             String?
  agency_id              String?
  contacts               Contact[]
  recurring_configs      RecurringConfig[]
  addresses              SupplierAddress[]
  transactions           Transaction[]
  agency                 Agency?           @relation(fields: [agency_id], references: [id])
  company                Company          @relation(fields: [company_id], references: [id])

  @@unique([company_id, internal_code])
  @@index([cnpj])
  @@index([cpf])
  @@index([agency_id])
  @@index([company_id])
}

model SupplierAddress {
  id          String    @id @default(uuid())
  supplier_id String
  address_id  String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  address     Address   @relation(fields: [address_id], references: [id])
  supplier    Supplier  @relation(fields: [supplier_id], references: [id])

  @@index([supplier_id])
  @@index([address_id])
}

model Transaction {
  id                       String               @id @default(uuid())
  company_id               String
  event_date               DateTime             @db.Date
  effective_date           DateTime             @db.Date
  purchase_date            DateTime?            @db.Date
  description              String
  amount                   Decimal              @db.Decimal(20, 2)
  status                   TransactionStatus    @default(PENDING)
  category_id              String
  subcategory_id           String?
  financial_institution_id String
  card_id                  String?
  center_id                String?
  created_at               DateTime             @default(now())
  updated_at               DateTime             @updatedAt
  deleted_at               DateTime?
  supplier_id              String?
  installment_number       Int?
  is_recurring             Boolean              @default(false)
  occurrence_number        Int?
  parent_transaction_id    String?
  payment_mode             PaymentMode?
  recurring_frequency      RecurringFrequency?
  recurring_group_id       String?
  total_installments       Int?
  invoice_id               String?
  lease_id                 String?
  transfer_group_id        String?
  is_transfer              Boolean              @default(false)
  is_cancellation_charge   Boolean              @default(false)
  card                     Card?                @relation(fields: [card_id], references: [id])
  category                 Category             @relation(fields: [category_id], references: [id])
  center                   Center?              @relation(fields: [center_id], references: [id])
  financial_institution    FinancialInstitution @relation(fields: [financial_institution_id], references: [id])
  invoice                  Invoice?             @relation(fields: [invoice_id], references: [id])
  lease                    Lease?               @relation(fields: [lease_id], references: [id])
  parent_transaction       Transaction?         @relation("TransactionToChildren", fields: [parent_transaction_id], references: [id])
  child_transactions       Transaction[]        @relation("TransactionToChildren")
  recurring_config         RecurringConfig?     @relation(fields: [recurring_group_id], references: [id])
  subcategory              Subcategory?         @relation(fields: [subcategory_id], references: [id])
  supplier                 Supplier?            @relation(fields: [supplier_id], references: [id])
  company                  Company             @relation(fields: [company_id], references: [id])

  @@index([category_id])
  @@index([subcategory_id])
  @@index([financial_institution_id])
  @@index([card_id])
  @@index([center_id])
  @@index([supplier_id])
  @@index([parent_transaction_id])
  @@index([recurring_group_id])
  @@index([payment_mode])
  @@index([invoice_id])
  @@index([lease_id])
  @@index([transfer_group_id])
  @@index([company_id])
}

model Invoice {
  id             String            @id @default(uuid())
  company_id     String
  card_id        String
  month          Int
  year           Int
  total_amount   Decimal           @default(0) @db.Decimal(20, 2)
  status         TransactionStatus @default(PENDING)
  closing_date   DateTime?         @db.Date
  due_date       DateTime?         @db.Date
  paid_date      DateTime?         @db.Date
  paid_amount    Decimal           @default(0) @db.Decimal(20, 2)
  institution_id String?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  deleted_at     DateTime?
  transactions   Transaction[]
  card           Card              @relation(fields: [card_id], references: [id])
  company        Company          @relation(fields: [company_id], references: [id])

  @@unique([card_id, month, year])
  @@index([card_id])
  @@index([status])
  @@index([company_id])
  @@map("invoices")
}

model RecurringConfig {
  id                       String               @id @default(uuid())
  company_id               String
  description              String
  amount                   Decimal              @db.Decimal(20, 2)
  frequency                RecurringFrequency
  category_id              String
  subcategory_id           String?
  financial_institution_id String
  card_id                  String?
  center_id                String?
  supplier_id              String?
  start_date               DateTime             @db.Date
  end_date                 DateTime?            @db.Date
  next_generation_date     DateTime?            @db.Date
  is_active                Boolean              @default(true)
  total_occurrences        Int?
  generated_occurrences    Int                  @default(0)
  created_at               DateTime             @default(now())
  updated_at               DateTime             @updatedAt
  deleted_at               DateTime?
  card                     Card?                @relation(fields: [card_id], references: [id])
  category                 Category             @relation(fields: [category_id], references: [id])
  center                   Center?              @relation(fields: [center_id], references: [id])
  financial_institution    FinancialInstitution @relation(fields: [financial_institution_id], references: [id])
  subcategory              Subcategory?         @relation(fields: [subcategory_id], references: [id])
  supplier                 Supplier?            @relation(fields: [supplier_id], references: [id])
  transactions             Transaction[]
  company                  Company             @relation(fields: [company_id], references: [id])

  @@index([category_id])
  @@index([subcategory_id])
  @@index([financial_institution_id])
  @@index([card_id])
  @@index([center_id])
  @@index([supplier_id])
  @@index([is_active])
  @@index([company_id])
}

// ─── PLANEJAMENTO ─────────────────────────────────────────────────────────────

model Planning {
  id              String          @id @default(uuid())
  company_id      String
  category_id     String
  subcategory_id  String?
  type            PlanningType
  default_amount  Decimal?        @db.Decimal(20, 2)
  min_recommended Decimal?        @db.Decimal(20, 2)
  max_recommended Decimal?        @db.Decimal(20, 2)
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  deleted_at      DateTime?

  category       Category        @relation(fields: [category_id], references: [id])
  subcategory    Subcategory?    @relation(fields: [subcategory_id], references: [id])
  monthly_values PlanningMonth[]
  company        Company        @relation(fields: [company_id], references: [id])

  // Sem @@unique aqui de propósito: a base de produção já tem combinações
  // duplicadas de (company_id, category_id, subcategory_id) que não podem ser
  // tocadas. A unicidade é garantida em código — ver PlanningService.assertUniqueCombination.
  @@index([category_id])
  @@index([subcategory_id])
  @@index([company_id])
}

model PlanningMonth {
  id          String   @id @default(uuid())
  planning_id String
  month       Int
  amount      Decimal  @db.Decimal(20, 2)

  planning Planning @relation(fields: [planning_id], references: [id], onDelete: Cascade)

  @@unique([planning_id, month])
  @@index([planning_id])
}

